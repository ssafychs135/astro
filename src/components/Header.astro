---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<header class="sticky top-0 z-50 glass-panel" transition:persist>
	<nav class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
		<div class="flex items-center gap-4">
			<a href={`${base}/`} class="text-xl font-black tracking-tighter hover:text-primary transition-colors tech-font">
				{SITE_TITLE} // <span class="text-primary">CORE</span>
			</a>
		</div>

		<!-- Desktop Navigation -->
		<div class="hidden md:flex items-center gap-10">
			<HeaderLink href={`${base}/portfolio`} class="tech-font text-xs tracking-[0.2em] opacity-70 hover:opacity-100 hover:text-primary font-bold">01_Portfolio</HeaderLink>
			<HeaderLink href={`${base}/blog`} class="tech-font text-xs tracking-[0.2em] opacity-70 hover:opacity-100 hover:text-primary font-bold">02_Research</HeaderLink>
			<HeaderLink href={`${base}/study`} class="tech-font text-xs tracking-[0.2em] opacity-70 hover:opacity-100 hover:text-primary font-bold">03_Study_Log</HeaderLink>
			<HeaderLink href={`${base}/about`} class="tech-font text-xs tracking-[0.2em] opacity-70 hover:opacity-100 hover:text-primary font-bold">04_Identity</HeaderLink>
		</div>

		<div class="flex items-center gap-6">
			<!-- System Status (Visible on all screens) -->
			<div class="flex items-center gap-3">
				<div class="pulse-dot"></div>
				<span class="tech-font text-[10px] font-bold opacity-50 tracking-widest hidden sm:inline">System_Online</span>
			</div>

			<!-- Hamburger Menu Button (Mobile Only) -->
			<button id="menu-toggle" class="md:hidden flex flex-col gap-1.5 p-2 z-50 group" aria-label="Toggle Menu">
				<div class="w-6 h-0.5 bg-primary transition-all duration-300 group-[.open]:rotate-45 group-[.open]:translate-y-2"></div>
				<div class="w-6 h-0.5 bg-primary transition-all duration-300 group-[.open]:opacity-0"></div>
				<div class="w-4 h-0.5 bg-primary self-end transition-all duration-300 group-[.open]:-rotate-45 group-[.open]:-translate-y-2 group-[.open]:w-6"></div>
			</button>
		</div>
	</nav>

	<!-- Mobile Menu Overlay -->
	<div id="mobile-menu" class="fixed inset-0 z-40 bg-bg-base/95 backdrop-blur-xl translate-x-full transition-transform duration-500 ease-[cubic-bezier(0.4,0,0.2,1)] md:hidden flex flex-col items-center justify-center gap-12">
		<nav class="flex flex-col items-center gap-8">
			<HeaderLink href={`${base}/portfolio`} class="tech-font text-2xl tracking-[0.3em] font-black hover:text-primary transition-colors mobile-link opacity-0">01_Portfolio</HeaderLink>
			<HeaderLink href={`${base}/blog`} class="tech-font text-2xl tracking-[0.3em] font-black hover:text-primary transition-colors mobile-link opacity-0">02_Research</HeaderLink>
			<HeaderLink href={`${base}/study`} class="tech-font text-2xl tracking-[0.3em] font-black hover:text-primary transition-colors mobile-link opacity-0">03_Study_Log</HeaderLink>
			<HeaderLink href={`${base}/about`} class="tech-font text-2xl tracking-[0.3em] font-black hover:text-primary transition-colors mobile-link opacity-0">04_Identity</HeaderLink>
		</nav>
		<div class="absolute bottom-12 flex flex-col items-center gap-4">
			<div class="pulse-dot scale-150"></div>
			<span class="tech-font text-xs font-bold opacity-50 tracking-[0.5em]">Command_Center</span>
		</div>
	</div>
</header>

<script>
	function setupMobileMenu() {
		const toggle = document.getElementById('menu-toggle');
		const menu = document.getElementById('mobile-menu');
		const links = document.querySelectorAll('.mobile-link');
		let isOpen = false;

		if (!toggle || !menu) return;

		function toggleMenu() {
			isOpen = !isOpen;
			toggle?.classList.toggle('open', isOpen);
			menu?.classList.toggle('translate-x-full', !isOpen);
			
			if (isOpen) {
				document.body.style.overflow = 'hidden';
				links.forEach((link, i) => {
					setTimeout(() => {
						(link as HTMLElement).style.opacity = '1';
						(link as HTMLElement).style.transform = 'translateY(0)';
					}, 200 + (i * 100));
				});
			} else {
				document.body.style.overflow = '';
				links.forEach(link => {
					(link as HTMLElement).style.opacity = '0';
					(link as HTMLElement).style.transform = 'translateY(20px)';
				});
			}
		}

		toggle.addEventListener('click', toggleMenu);

		// Close menu on link click
		links.forEach(link => {
			link.addEventListener('click', () => {
				if (isOpen) toggleMenu();
			});
		});
	}

	// Run on initial load
	setupMobileMenu();
	// Run on view transitions
	document.addEventListener('astro:after-swap', setupMobileMenu);
</script>

<style>
	header {
		border-bottom: 1px solid rgba(255, 255, 255, 0.05);
	}
	.mobile-link {
		transform: translateY(20px);
		transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
	}
</style>
