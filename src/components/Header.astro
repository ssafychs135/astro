---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<header class="sticky top-0 z-50 glass-panel" transition:persist>
	<nav class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
		<div class="flex items-center gap-4">
			<a href={`${base}/`} class="text-lg font-black tracking-tighter hover:text-primary transition-colors tech-font">
				{SITE_TITLE} // <span class="text-primary">CORE</span>
			</a>
		</div>
		<div class="hidden md:flex items-center gap-8">
			<HeaderLink href={`${base}/portfolio`} class="tech-font text-[10px] tracking-widest opacity-60 hover:opacity-100 hover:text-primary">01_Portfolio</HeaderLink>
			<HeaderLink href={`${base}/blog`} class="tech-font text-[10px] tracking-widest opacity-60 hover:opacity-100 hover:text-primary">02_Research</HeaderLink>
			<HeaderLink href={`${base}/study`} class="tech-font text-[10px] tracking-widest opacity-60 hover:opacity-100 hover:text-primary">03_Study_Log</HeaderLink>
			<HeaderLink href={`${base}/about`} class="tech-font text-[10px] tracking-widest opacity-60 hover:opacity-100 hover:text-primary">04_Identity</HeaderLink>
		</div>
		<div class="flex items-center gap-2">
			<div class="pulse-dot"></div>
			<span class="tech-font text-[9px] opacity-40">System_Online</span>
		</div>
	</nav>
</header>

<style>
	header {
		border-bottom: 1px solid rgba(255, 255, 255, 0.05);
	}
</style>
