---
const today = new Date();
---

<footer class="mt-32 border-t border-surface-highest/20 bg-surface-low py-16" transition:persist>
	<div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-3 gap-12">
		<div>
			<div class="tech-font text-xs font-black mb-6">THE AX STRATEGIST</div>
			<p class="text-text-muted text-xs leading-relaxed max-w-xs">
				Designing intelligent systems and architecting future-proof business workflows through AI Experience (AX).
			</p>
		</div>
		<div>
			<div class="tech-font text-[10px] opacity-40 mb-6 uppercase tracking-widest">Connect_Channels</div>
			<ul class="space-y-3 text-sm list-none p-0 m-0">
				<li><a href="https://github.com" class="hover:text-primary transition-colors">GitHub // Source</a></li>
				<li><a href="https://linkedin.com" class="hover:text-primary transition-colors">LinkedIn // Professional</a></li>
				<li><a href="mailto:contact@example.com" class="hover:text-primary transition-colors">Mail // Initialize</a></li>
			</ul>
		</div>
		<div class="flex flex-col justify-between items-end">
			<div class="tech-font text-[10px] opacity-30 text-right">
				LATENCY: 24MS<br/>
				REGION: KR-SEOUL-01<br/>
				UPTIME: 100%
			</div>
			<div class="text-[9px] tech-font opacity-40 mt-8">
				&copy; {today.getFullYear()} // SYSTEM_USER // ALL_RIGHTS_RESERVED
			</div>
		</div>
	</div>
</footer>
