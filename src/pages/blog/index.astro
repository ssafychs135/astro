---
import MainLayout from '../../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<MainLayout title={`Tech Research | ${SITE_TITLE}`} description={SITE_DESCRIPTION}>
	<header class="mb-24">
		<div class="tech-label mb-6">> System_Insights // Strategic_Research</div>
		<h1 class="text-6xl md:text-9xl font-black tracking-tighter uppercase mb-8 font-space-grotesk">
			Tech<br/><span class="text-primary italic">Research</span>
		</h1>
		<p class="text-xl text-text-muted max-w-2xl leading-relaxed">
			AX 트렌드와 시스템 설계에 대한 심층적인 분석 리포트입니다. 
			단순한 정보 전달을 넘어, 기술이 비즈니스에 미치는 영향력을 탐구합니다.
		</p>
	</header>

	<div class="bg-black/50 backdrop-blur-md rounded-sm border border-surface-highest/30 overflow-hidden">
		<div class="grid grid-cols-12 gap-4 px-8 py-4 border-b border-surface-highest/30 bg-surface-low/50 tech-font text-[9px] opacity-40">
			<div class="col-span-2">TIMESTAMP</div>
			<div class="col-span-8">INSIGHT_TITLE</div>
			<div class="col-span-2 text-right">METADATA</div>
		</div>
		{posts.map((post) => (
			<a href={`${base}/blog/${post.id}/`} class="grid grid-cols-12 gap-4 px-8 py-6 border-b border-white/5 hover:bg-primary/5 transition-colors group no-underline">
				<div class="col-span-2 tech-font text-[10px] text-text-muted mt-1">
					<FormattedDate date={post.data.pubDate} />
				</div>
				<div class="col-span-8">
					<div class="font-bold text-lg group-hover:text-primary transition-colors font-space-grotesk uppercase">{post.data.title}</div>
					<p class="text-xs text-text-muted mt-2 line-clamp-1 opacity-60 font-sans">{post.data.description}</p>
				</div>
				<div class="col-span-2 text-right tech-font text-[9px] text-secondary opacity-60 mt-1 uppercase">
					Entry // 0{posts.indexOf(post) + 1}
				</div>
			</a>
		))}
	</div>
</MainLayout>
