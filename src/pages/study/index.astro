---
import MainLayout from '../../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const notes = (await getCollection('study')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<MainLayout title={`Study Log | ${SITE_TITLE}`} description={SITE_DESCRIPTION}>
	<header class="mb-24">
		<div class="tech-label mb-6">> System_Exploration // Continuous_Learning</div>
		<h1 class="text-6xl md:text-9xl font-black tracking-tighter uppercase mb-8 font-space-grotesk">
			Study<br/><span class="text-secondary italic">Log</span>
		</h1>
		<p class="text-xl text-text-muted max-w-2xl leading-relaxed">
			기술적 한계를 돌파하기 위한 매일의 기록입니다. 
			성공보다 실패의 기록에 더 집중하며, 지능형 시스템의 견고함을 쌓아가는 연구 노트입니다.
		</p>
	</header>

	<div class="bg-black/50 backdrop-blur-md rounded-sm border border-surface-highest/30 overflow-hidden">
		<div class="grid grid-cols-12 gap-4 px-8 py-4 border-b border-surface-highest/30 bg-surface-low/50 tech-font text-[9px] opacity-40">
			<div class="col-span-2">LOG_TIMESTAMP</div>
			<div class="col-span-8">RESEARCH_TITLE</div>
			<div class="col-span-2 text-right">TAGS</div>
		</div>
		{notes.map((note) => (
			<a href={`${base}/study/${note.id}/`} class="grid grid-cols-12 gap-4 px-8 py-6 border-b border-white/5 hover:bg-secondary/5 transition-colors group no-underline">
				<div class="col-span-2 tech-font text-[10px] text-text-muted mt-1">
					<FormattedDate date={note.data.pubDate} />
				</div>
				<div class="col-span-8">
					<div class="font-bold text-lg group-hover:text-secondary transition-colors font-space-grotesk uppercase">{note.data.title}</div>
					<p class="text-xs text-text-muted mt-2 line-clamp-1 opacity-60 font-sans">{note.data.description}</p>
				</div>
				<div class="col-span-2 text-right flex flex-wrap justify-end gap-2 mt-1">
					{note.data.tags?.slice(0, 2).map(tag => <span class="text-[9px] tech-font text-secondary opacity-50">#{tag}</span>)}
				</div>
			</a>
		))}
	</div>
</MainLayout>
