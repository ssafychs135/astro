---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body class="bg-white text-slate-900 font-inter">
		<Header />
		<main class="max-w-7xl mx-auto px-6 py-12 md:py-32">
			<!-- Hero Section -->
			<section class="mb-32">
				<div class="mb-6 font-space-grotesk text-accent font-bold tracking-widest text-xs uppercase">Welcome to my Digital Garden</div>
				<h1 class="text-7xl md:text-[120px] font-plus-jakarta font-extrabold tracking-tighter leading-[0.9] mb-12">
					Growth-driven <br />
					<span class="text-accent">Developer</span> SEO.
				</h1>
				<div class="flex flex-col md:flex-row gap-16 items-start">
					<div class="md:w-3/5">
						<p class="text-2xl md:text-3xl text-slate-500 leading-relaxed font-light">
							끊임없이 배우고 기록하며, 지식의 파편들을 모아 견고한 정원을 만듭니다. 
							단순한 코딩을 넘어 기술의 본질을 탐구하고 성장의 궤적을 공유합니다.
						</p>
					</div>
					<div class="md:w-2/5 relative w-full flex justify-center">
						<!-- Digital Garden Motif (Abstract Visual) -->
						<div class="relative w-64 h-64">
							<div class="absolute inset-0 bg-blue-50 rounded-full blur-3xl opacity-60"></div>
							<div class="relative grid grid-cols-3 gap-3">
								<div class="w-16 h-16 bg-accent rounded-2xl rotate-12 shadow-lg shadow-blue-200"></div>
								<div class="w-16 h-16 bg-accent-secondary border-2 border-blue-100 rounded-full -translate-y-4"></div>
								<div class="w-16 h-16 bg-accent-success rounded-3xl -rotate-12 translate-x-4"></div>
								<div class="w-16 h-16 border-2 border-accent rounded-full translate-y-4"></div>
								<div class="w-16 h-16 bg-blue-600 rounded-2xl scale-110 shadow-xl"></div>
								<div class="w-16 h-16 bg-slate-100 rounded-full"></div>
							</div>
						</div>
					</div>
				</div>
			</section>


			<!-- Section Navigation Cards -->
			<section class="grid grid-cols-1 md:grid-cols-3 gap-8">
				<!-- Tech Research -->
				<a href={`${base}/blog`} class="group block bg-slate-50/50 border border-slate-100 p-10 rounded-[32px] hover:border-accent hover:bg-white transition-all duration-500">
					<div class="mb-12 flex justify-between items-start">
						<span class="font-space-grotesk text-[10px] text-slate-400 font-bold uppercase tracking-[0.2em]">Section 01</span>
						<div class="w-12 h-12 rounded-full border border-slate-200 flex items-center justify-center text-slate-400 group-hover:bg-accent group-hover:text-white group-hover:border-accent transition-all duration-500">
							<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
								<path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
							</svg>
						</div>
					</div>
					<h3 class="text-3xl font-plus-jakarta font-extrabold mb-4 tracking-tight group-hover:text-accent transition-colors duration-500">Tech Research</h3>
					<p class="text-slate-500 leading-relaxed font-light">깊이 있는 기술 분석과 트렌드 조사 리포트</p>
				</a>

				<!-- Growth Log -->
				<a href={`${base}/study`} class="group block bg-slate-50/50 border border-slate-100 p-10 rounded-[32px] hover:border-accent-success hover:bg-white transition-all duration-500">
					<div class="mb-12 flex justify-between items-start">
						<span class="font-space-grotesk text-[10px] text-slate-400 font-bold uppercase tracking-[0.2em]">Section 02</span>
						<div class="w-12 h-12 rounded-full border border-slate-200 flex items-center justify-center text-slate-400 group-hover:bg-accent-success group-hover:text-white group-hover:border-accent-success transition-all duration-500">
							<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
								<path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
							</svg>
						</div>
					</div>
					<h3 class="text-3xl font-plus-jakarta font-extrabold mb-4 tracking-tight group-hover:text-accent-success transition-colors duration-500">Growth Log</h3>
					<p class="text-slate-500 leading-relaxed font-light">매일의 학습과 트러블슈팅의 기록</p>
				</a>

				<!-- Portfolio -->
				<a href={`${base}/portfolio`} class="group block bg-slate-50/50 border border-slate-100 p-10 rounded-[32px] hover:border-accent-secondary hover:bg-white transition-all duration-500">
					<div class="mb-12 flex justify-between items-start">
						<span class="font-space-grotesk text-[10px] text-slate-400 font-bold uppercase tracking-[0.2em]">Section 03</span>
						<div class="w-12 h-12 rounded-full border border-slate-200 flex items-center justify-center text-slate-400 group-hover:bg-accent-secondary group-hover:text-white group-hover:border-accent-secondary transition-all duration-500">
							<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
								<path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
							</svg>
						</div>
					</div>
					<h3 class="text-3xl font-plus-jakarta font-extrabold mb-4 tracking-tight group-hover:text-accent-secondary transition-colors duration-500">Portfolio</h3>
					<p class="text-slate-500 leading-relaxed font-light">경험과 배움이 응축된 최종 결과물</p>
				</a>
			</section>
		</main>
		<Footer />
	</body>
</html>
