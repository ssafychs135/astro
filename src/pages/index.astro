---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body class="bg-[#030712] text-slate-50 font-inter antialiased">
		<Header />
		<main class="max-w-7xl mx-auto px-6 py-12 md:py-32">
			<!-- Hero Section -->
			<section class="mb-40">
				<div class="mb-8 font-space-grotesk text-accent font-bold tracking-[0.3em] text-[10px] uppercase border-l-2 border-accent pl-4">
					Strategic Intelligence & AI Transformation
				</div>
				<h1 class="text-6xl md:text-[110px] font-space-grotesk font-bold tracking-tighter leading-[0.85] mb-16">
					Architecting <br />
					the Future of <br />
					<span class="text-accent">AI Transformation.</span>
				</h1>
				<div class="flex flex-col md:flex-row gap-20 items-start">
					<div class="md:w-3/5">
						<p class="text-2xl md:text-3xl text-slate-400 leading-relaxed font-light mb-10">
							Bridging the gap between <span class="text-white font-medium">Artificial Intelligence</span> and <span class="text-white font-medium">Business Strategy</span>. 
							지능형 자동화와 데이터 기반 통찰로 기업의 새로운 가치를 창출합니다.
						</p>
						<div class="flex gap-6">
							<div class="flex flex-col">
								<span class="font-space-grotesk text-[10px] text-slate-500 uppercase tracking-widest mb-1">Status</span>
								<span class="flex items-center gap-2 text-xs font-bold text-accent">
									<span class="w-2 h-2 rounded-full bg-accent animate-pulse"></span>
									READY FOR AX TRANSFORMATION
								</span>
							</div>
						</div>
					</div>
					<div class="md:w-2/5 relative w-full flex justify-center pt-10">
						<!-- Technical Motif (Neural Grid) -->
						<div class="relative w-72 h-72">
							<div class="absolute inset-0 bg-accent/10 rounded-full blur-3xl opacity-40"></div>
							<div class="relative grid grid-cols-4 gap-1 p-4 border border-slate-800 bg-slate-900/50 backdrop-blur-xl">
								{Array.from({ length: 16 }).map((_, i) => (
									<div class={`aspect-square border border-slate-800 flex items-center justify-center ${i % 5 === 0 ? 'bg-accent/20' : ''}`}>
										{i % 7 === 0 && <div class="w-1.5 h-1.5 bg-accent shadow-[0_0_10px_#10b981]"></div>}
										{i === 10 && <div class="w-1.5 h-1.5 bg-accent-secondary shadow-[0_0_10px_#a855f7]"></div>}
									</div>
								))}
							</div>
							<div class="absolute -top-4 -right-4 font-space-grotesk text-[8px] text-accent-secondary opacity-50 select-none">
								[SYSTEM_ID: AX_01]
							</div>
						</div>
					</div>
				</div>
			</section>


			<!-- Section Navigation Cards (AX Pillars) -->
			<section class="grid grid-cols-1 md:grid-cols-3 gap-10">
				<!-- AX Strategy -->
				<a href={`${base}/blog`} class="group block bg-slate-900/30 border border-slate-800 p-10 rounded-sm hover:border-accent transition-all duration-500 relative overflow-hidden">
					<div class="absolute top-0 right-0 p-4 opacity-10 group-hover:opacity-30 transition-opacity">
						<svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M3 3v18h18M7 16l4-4 4 4 6-6"/></svg>
					</div>
					<div class="mb-16">
						<span class="font-space-grotesk text-[10px] text-slate-500 font-bold uppercase tracking-[0.3em]">Module 01</span>
					</div>
					<h3 class="text-3xl font-space-grotesk font-bold mb-4 tracking-tight group-hover:text-accent transition-colors">AX Strategy</h3>
					<p class="text-slate-400 leading-relaxed font-light text-sm">AI 도입 전략, ROI 분석 및 산업별 혁신 사례 연구 리포트</p>
					<div class="mt-10 flex items-center gap-2 text-[10px] font-bold font-space-grotesk tracking-widest text-accent opacity-0 group-hover:opacity-100 transition-all">
						OPEN_MODULE <span class="text-xs">→</span>
					</div>
				</a>

				<!-- AI Implementation -->
				<a href={`${base}/study`} class="group block bg-slate-900/30 border border-slate-800 p-10 rounded-sm hover:border-accent-secondary transition-all duration-500 relative overflow-hidden">
					<div class="absolute top-0 right-0 p-4 opacity-10 group-hover:opacity-30 transition-opacity">
						<svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M12 2v20M2 12h20M12 2l4 4M12 22l-4-4M2 12l4-4M22 12l-4 4"/></svg>
					</div>
					<div class="mb-16">
						<span class="font-space-grotesk text-[10px] text-slate-500 font-bold uppercase tracking-[0.3em]">Module 02</span>
					</div>
					<h3 class="text-3xl font-space-grotesk font-bold mb-4 tracking-tight group-hover:text-accent-secondary transition-colors">AI Implementation</h3>
					<p class="text-slate-400 leading-relaxed font-light text-sm">LLM 파이프라인, RAG 아키텍처 및 자율형 에이전트 구축 기술 로그</p>
					<div class="mt-10 flex items-center gap-2 text-[10px] font-bold font-space-grotesk tracking-widest text-accent-secondary opacity-0 group-hover:opacity-100 transition-all">
						OPEN_MODULE <span class="text-xs">→</span>
					</div>
				</a>

				<!-- AX Solutions -->
				<a href={`${base}/portfolio`} class="group block bg-slate-900/30 border border-slate-800 p-10 rounded-sm hover:border-white transition-all duration-500 relative overflow-hidden">
					<div class="absolute top-0 right-0 p-4 opacity-10 group-hover:opacity-30 transition-opacity">
						<svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
					</div>
					<div class="mb-16">
						<span class="font-space-grotesk text-[10px] text-slate-500 font-bold uppercase tracking-[0.3em]">Module 03</span>
					</div>
					<h3 class="text-3xl font-space-grotesk font-bold mb-4 tracking-tight group-hover:text-white transition-colors">Portfolio</h3>
					<p class="text-slate-400 leading-relaxed font-light text-sm">실제 문제를 해결한 프로젝트 쇼케이스 및 솔루션</p>
					<div class="mt-10 flex items-center gap-2 text-[10px] font-bold font-space-grotesk tracking-widest text-white opacity-0 group-hover:opacity-100 transition-all">
						OPEN_MODULE <span class="text-xs">→</span>
					</div>
				</a>
			</section>
		</main>
		<Footer />
	</body>
</html>
body>
</html>
