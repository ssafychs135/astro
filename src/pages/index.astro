---
import MainLayout from '../layouts/MainLayout.astro';
import { getCollection, render } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// 1. 포트폴리오 컬렉션 전체 로드 (상세 내용 포함)
const projects = (await getCollection('portfolio')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// 2. 최신 연구 로그 요약 (하단 트랙용)
const latestLogs = [
	...(await getCollection('blog')),
	...(await getCollection('study'))
].sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()).slice(0, 3);

// 3. 스킬 데이터 정의 (단계형)
const coreSpecs = [
	{ name: 'RAG_ARCHITECTURE', level: 5, status: 'OPTIMAL' },
	{ name: 'AGENTIC_WORKFLOW', level: 4, status: 'ACTIVE' },
	{ name: 'FULLSTACK_DEV', level: 5, status: 'STABLE' },
	{ name: 'MODEL_TUNING', level: 4, status: 'TUNING' }
];
---

<MainLayout title={`Portfolio Master | ${SITE_TITLE}`} description={SITE_DESCRIPTION}>
	<div class="grid grid-cols-12 gap-12 relative">
		<!-- Main Narrative Area (Left/Center) -->
		<div class="col-span-12 lg:col-span-9 space-y-32">
			
			<!-- SECTION 01: IDENTITY & RESUME -->
			<section id="identity" class="min-h-[60vh] flex flex-col justify-center">
				<div class="flex flex-col md:flex-row gap-16 items-start md:items-center mb-24">
					<!-- Profile Image -->
					<div class="relative group shrink-0">
						<div class="absolute -inset-1 bg-gradient-to-tr from-primary to-secondary rounded-sm blur opacity-25 group-hover:opacity-50 transition duration-1000"></div>
						<div class="relative w-48 h-48 md:w-64 md:h-64 bg-surface-low rounded-sm overflow-hidden border border-white/5">
							<div class="w-full h-full flex items-center justify-center tech-font text-sm opacity-30">PROFILE_IMG</div>
						</div>
					</div>
					
					<div class="space-y-8">
						<div class="tech-label text-lg font-bold">
							<div class="pulse-dot scale-125"></div>
							Agent_Status: Active // Level: Senior AX Engineer
						</div>
						<h1 class="text-6xl md:text-[100px] font-black tracking-tighter uppercase font-space-grotesk leading-[0.85]">
							Building<br/><span class="text-primary italic">AX Solutions</span>
						</h1>
						<p class="text-2xl md:text-3xl text-text-muted leading-relaxed max-w-3xl">
							데이터의 흐름을 설계하고 비즈니스 가치를 구현하는 <span class="text-white font-bold underline decoration-primary decoration-4 underline-offset-8">AX 개발자 최형선</span>입니다.
						</p>
					</div>
				</div>

				<!-- Telemetry Resume: Experience & Skills (Segmented Steps) -->
				<div class="grid grid-cols-1 md:grid-cols-3 gap-16 py-20 border-y border-surface-highest/20">
					<div class="space-y-8">
						<span class="tech-label text-base opacity-50 font-bold">Experience_Timeline</span>
						<ul class="text-base space-y-8 list-none p-0 opacity-90">
							<li><span class="text-secondary font-black text-lg">2024 - Present</span><br/>AX Systems Lead // AI Startup</li>
							<li><span class="text-secondary font-black text-lg">2022 - 2024</span><br/>Full-stack Developer // Web Agency</li>
						</ul>
					</div>
					<div class="space-y-8 md:col-span-2">
						<span class="tech-label text-base opacity-50 font-bold">Core_Engine_Specs (Expertise_Level)</span>
						<div class="grid grid-cols-1 md:grid-cols-2 gap-x-20 gap-y-12">
							{coreSpecs.map((spec) => (
								<div class="space-y-4">
									<div class="flex justify-between text-[11px] tech-font font-black tracking-widest">
										<span class="opacity-60">{spec.name}</span>
										<span class="text-primary tracking-tighter">{spec.status}</span>
									</div>
									<div class="flex gap-1.5">
										{[1, 2, 3, 4, 5].map((step) => (
											<div class={`h-3 flex-1 rounded-sm transition-all duration-500 ${step <= spec.level ? 'bg-primary shadow-[0_0_10px_var(--primary)]' : 'bg-surface-highest opacity-20'}`}></div>
										))}
									</div>
									<div class="flex justify-between text-[9px] tech-font opacity-30 font-bold">
										<span>LVL_01</span>
										<span>LVL_05</span>
									</div>
								</div>
							))}
						</div>
					</div>
				</div>
			</section>

			<!-- SECTION 02: VERIFIED SOLUTIONS (DEEP-DIVE) -->
			<section id="work" class="space-y-48">
				<div class="border-b border-surface-highest/20 pb-8">
					<span class="tech-label text-secondary text-xl mb-4 font-bold">> Track_A // Master_Evidence</span>
					<h2 class="text-6xl md:text-8xl font-black uppercase tracking-tighter">Case Studies</h2>
				</div>

				{projects.map(async (project) => {
					const { Content } = await render(project);
					return (
						<article class="project-deep-dive space-y-20">
							<header class="space-y-10">
								<div class="flex items-end justify-between border-l-[6px] border-primary pl-10">
									<div>
										<div class="tech-label text-sm opacity-50 mb-3 font-black">Record_0{projects.indexOf(project) + 1}</div>
										<h3 class="text-5xl md:text-[80px] font-black tracking-tighter uppercase font-space-grotesk leading-none">{project.data.title}</h3>
									</div>
									<div class="text-right hidden md:block">
										<div class="tech-label text-xs opacity-40 mb-3 font-bold">Timestamp</div>
										<div class="tech-font text-base font-bold text-secondary tracking-widest"><FormattedDate date={project.data.pubDate} /></div>
									</div>
								</div>
								<p class="text-2xl md:text-4xl text-text-muted leading-tight max-w-5xl font-medium tracking-tight">
									{project.data.description}
								</p>
							</header>

							<!-- Architecture / Hero Visual -->
							<div class="bg-surface-low p-4 md:p-16 rounded-sm relative overflow-hidden group">
								<div class="relative aspect-video rounded-sm overflow-hidden border border-white/5 bg-surface-highest/30">
									{project.data.heroImage && <img src={project.data.heroImage} alt="" class="w-full h-full object-cover grayscale opacity-40 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-1000" />}
									<div class="absolute inset-0 p-12 pointer-events-none opacity-10 group-hover:opacity-20 transition-opacity">
										<svg width="100%" height="100%" viewBox="0 0 100 100" class="text-primary stroke-current fill-none stroke-[0.2]">
											<path d="M0 0l100 100M100 0L0 100M50 0v100M0 50h100" />
											<circle cx="50" cy="50" r="40" />
										</svg>
									</div>
								</div>
								<div class="absolute top-12 right-12 tech-font text-xs opacity-50 text-right leading-relaxed font-black tracking-[0.3em]">
									CORE_SYSTEM_BLUEPRINT<br/>
									VERSION: 2.0.4<br/>
									STATUS: VERIFIED
								</div>
							</div>

							<!-- Detailed Content -->
							<div class="prose-obsidian max-w-none grid grid-cols-1 lg:grid-cols-12 gap-20">
								<div class="lg:col-span-4 space-y-16">
									<div class="p-10 bg-surface-low rounded-sm border border-surface-highest/30">
										<span class="tech-label text-sm mb-8 font-black">Tech_Stack</span>
										<div class="flex flex-wrap gap-4">
											{project.data.stack?.map(s => <span class="px-4 py-2 bg-surface-highest text-xs font-bold tech-font text-secondary rounded-sm tracking-widest">{s}</span>)}
										</div>
									</div>
									<div class="flex flex-col gap-6">
										{project.data.githubUrl && <a href={project.data.githubUrl} class="px-10 py-5 bg-primary text-bg-base font-black tech-font text-sm text-center rounded-sm hover:bg-secondary transition-all transform hover:-translate-y-1">[Initialize_Source]</a>}
										{project.data.demoUrl && <a href={project.data.demoUrl} class="px-10 py-5 border border-surface-high font-black tech-font text-sm text-center rounded-sm hover:border-primary transition-all transform hover:-translate-y-1">[Deploy_Live]</a>}
									</div>
								</div>
								<div class="lg:col-span-8">
									<div class="text-2xl leading-relaxed opacity-90">
										<Content />
									</div>
								</div>
							</div>
						</article>
					);
				})}
			</section>

			<!-- SECTION 03: LATEST RESEARCH -->
			<section id="logs" class="py-32">
				<div class="flex justify-between items-end mb-20 border-b border-white/5 pb-10">
					<div>
						<span class="tech-label text-primary text-xl mb-4 font-black">> Track_B // Learning_Loop</span>
						<h2 class="text-6xl font-bold uppercase tracking-tighter">Recent Exploration</h2>
					</div>
					<a href="/blog" class="tech-font text-sm opacity-50 hover:opacity-100 transition-opacity font-black">Access_Full_Archive_</a>
				</div>
				<div class="bg-black/50 backdrop-blur-md rounded-sm border border-surface-highest/30 overflow-hidden">
					{latestLogs.map((log) => (
						<a href={`/${log.collection}/${log.id}/`} class="grid grid-cols-12 gap-6 px-10 py-10 border-b border-white/5 hover:bg-primary/5 transition-colors group no-underline">
							<div class="col-span-2 tech-font text-sm text-text-muted mt-1 font-bold">
								<FormattedDate date={log.data.pubDate} />
							</div>
							<div class="col-span-8 font-bold text-2xl group-hover:text-primary transition-colors font-space-grotesk uppercase tracking-tight">
								{log.data.title}
							</div>
							<div class="col-span-2 text-right tech-font text-xs text-secondary opacity-60 mt-1 uppercase font-black tracking-widest">
								[{log.collection}]
							</div>
						</a>
					))}
				</div>
			</section>
		</div>

		<!-- Sticky Sidebar Widget (Right) -->
		<aside class="hidden lg:block lg:col-span-3">
			<div class="sticky top-28 space-y-16">
				<div class="glass-panel p-12 rounded-sm border-l-4 border-primary">
					<div class="tech-label text-sm mb-10 opacity-50 font-black">System_Diagnostics</div>
					<div class="space-y-8">
						<div class="flex items-center gap-5">
							<div class="w-3 h-3 bg-primary rounded-full shadow-[0_0_15px_var(--primary)]"></div>
							<span class="text-sm tech-font font-black tracking-[0.2em]">Core_System: ONLINE</span>
						</div>
						<div class="flex items-center gap-5">
							<div class="w-3 h-3 bg-secondary rounded-full shadow-[0_0_15px_var(--secondary)]"></div>
							<span class="text-sm tech-font font-black tracking-[0.2em]">AX_Protocol: ACTIVE</span>
						</div>
						<div class="flex items-center gap-5">
							<div class="w-3 h-3 bg-white rounded-full opacity-20"></div>
							<span class="text-sm tech-font opacity-40 font-black tracking-[0.2em]">Remote_Access: READY</span>
						</div>
					</div>
				</div>

				<nav class="p-12 border-l-2 border-white/10 space-y-8">
					<div class="tech-label text-xs mb-8 opacity-30 font-black">Navigation_Index</div>
					<a href="#identity" class="block text-sm tech-font font-black opacity-50 hover:opacity-100 hover:text-primary transition-all transform hover:translate-x-3 tracking-widest">01_Identity_Resume</a>
					<a href="#work" class="block text-sm tech-font font-black opacity-50 hover:opacity-100 hover:text-primary transition-all transform hover:translate-x-3 tracking-widest">02_Project_Showcase</a>
					<a href="#logs" class="block text-sm tech-font font-black opacity-50 hover:opacity-100 hover:text-primary transition-all transform hover:translate-x-3 tracking-widest">03_Research_Logs</a>
				</nav>
			</div>
		</aside>
	</div>
</MainLayout>

<style>
	.pulse-dot {
		width: 12px;
		height: 12px;
		background-color: var(--primary);
		border-radius: 50%;
		position: relative;
	}
	.pulse-dot::after {
		content: "";
		position: absolute;
		inset: 0;
		border-radius: 50%;
		background-color: var(--primary);
		animation: pulse 2s infinite;
	}
	@keyframes pulse {
		0% { transform: scale(1); opacity: 0.8; }
		100% { transform: scale(3); opacity: 0; }
	}
	
	.project-deep-dive:not(:last-child) {
		border-bottom: 1px solid rgba(255, 255, 255, 0.05);
		padding-bottom: var(--spacing-32);
	}
</style>
