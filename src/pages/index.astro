---
import MainLayout from '../layouts/MainLayout.astro';
import { getCollection, render } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// 1. 포트폴리오 컬렉션 전체 로드 (상세 내용 포함)
const projects = (await getCollection('portfolio')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// 2. 최신 연구 로그 요약 (하단 트랙용)
const latestLogs = [
	...(await getCollection('blog')),
	...(await getCollection('study'))
].sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()).slice(0, 3);
---

<MainLayout title={`Portfolio Master | ${SITE_TITLE}`} description={SITE_DESCRIPTION}>
	<div class="grid grid-cols-12 gap-12 relative">
		<!-- Main Narrative Area (Left/Center) -->
		<div class="col-span-12 lg:col-span-9 space-y-32">
			
			<!-- SECTION 01: IDENTITY & RESUME -->
			<section id="identity" class="min-h-[60vh] flex flex-col justify-center">
				<div class="flex flex-col md:flex-row gap-12 items-start md:items-center mb-16">
					<!-- Profile Image: Adjusted to be compact and professional -->
					<div class="relative group shrink-0">
						<div class="absolute -inset-1 bg-gradient-to-tr from-primary to-secondary rounded-sm blur opacity-25 group-hover:opacity-50 transition duration-1000"></div>
						<div class="relative w-40 h-40 md:w-56 md:h-56 bg-surface-low rounded-sm overflow-hidden border border-white/5">
							<!-- 실제 사진 파일이 있으면 여기에 경로 입력 -->
							<div class="w-full h-full flex items-center justify-center tech-font text-xs opacity-30">PROFILE_IMG</div>
						</div>
					</div>
					
					<div class="space-y-6">
						<div class="tech-label">
							<div class="pulse-dot"></div>
							Agent_Status: Active // Level: Senior AX Engineer
						</div>
						<h1 class="text-5xl md:text-8xl font-black tracking-tighter uppercase font-space-grotesk leading-none">
							Building<br/><span class="text-primary italic">AX Solutions</span>
						</h1>
						<p class="text-xl text-text-muted leading-relaxed max-w-2xl">
							복잡한 비즈니스 문제를 지능형 아키텍처로 해결하는 <span class="text-white font-bold">최형선</span>입니다. 
							데이터의 흐름을 설계하고, AI 기술을 실제 사용자 경험으로 전환하는 과정에 집중합니다.
						</p>
					</div>
				</div>

				<!-- Telemetry Resume: Experience & Skills -->
				<div class="grid grid-cols-1 md:grid-cols-3 gap-8 py-12 border-y border-surface-highest/20">
					<div class="space-y-4">
						<span class="tech-label opacity-40">Experience_Timeline</span>
						<ul class="text-xs space-y-4 list-none p-0 opacity-80">
							<li><span class="text-secondary font-bold">2024 - Present</span><br/>AX Systems Lead // AI Startup</li>
							<li><span class="text-secondary font-bold">2022 - 2024</span><br/>Full-stack Developer // Web Agency</li>
						</ul>
					</div>
					<div class="space-y-4 md:col-span-2">
						<span class="tech-label opacity-40">Core_Engine_Specs (Skills)</span>
						<div class="grid grid-cols-2 gap-x-12 gap-y-4">
							<div>
								<div class="flex justify-between text-[10px] tech-font mb-1"><span>RAG_ARCHITECTURE</span><span>95%</span></div>
								<div class="h-1 bg-surface-highest rounded-full overflow-hidden"><div class="h-full bg-primary" style="width: 95%"></div></div>
							</div>
							<div>
								<div class="flex justify-between text-[10px] tech-font mb-1"><span>AGENTIC_WORKFLOW</span><span>90%</span></div>
								<div class="h-1 bg-surface-highest rounded-full overflow-hidden"><div class="h-full bg-secondary" style="width: 90%"></div></div>
							</div>
							<div>
								<div class="flex justify-between text-[10px] tech-font mb-1"><span>FULLSTACK_DEV</span><span>92%</span></div>
								<div class="h-1 bg-surface-highest rounded-full overflow-hidden"><div class="h-full bg-white" style="width: 92%"></div></div>
							</div>
							<div>
								<div class="flex justify-between text-[10px] tech-font mb-1"><span>MODEL_TUNING</span><span>85%</span></div>
								<div class="h-1 bg-surface-highest rounded-full overflow-hidden"><div class="h-full bg-primary/50" style="width: 85%"></div></div>
							</div>
						</div>
					</div>
				</div>
			</section>

			<!-- SECTION 02: VERIFIED SOLUTIONS (DEEP-DIVE) -->
			<section id="work" class="space-y-48">
				<div class="border-b border-surface-highest/20 pb-8">
					<span class="tech-label text-secondary mb-4">> Track_A // Master_Evidence</span>
					<h2 class="text-4xl font-bold uppercase tracking-tighter">Case Studies</h2>
				</div>

				{projects.map(async (project) => {
					const { Content } = await render(project);
					return (
						<article class="project-deep-dive space-y-12">
							<header class="space-y-8">
								<div class="flex items-end justify-between border-l-2 border-primary pl-8">
									<div>
										<div class="tech-label text-[10px] opacity-40 mb-2">Record_0{projects.indexOf(project) + 1}</div>
										<h3 class="text-4xl md:text-6xl font-black tracking-tighter uppercase font-space-grotesk">{project.data.title}</h3>
									</div>
									<div class="text-right hidden md:block">
										<div class="tech-label opacity-40 mb-2">Timestamp</div>
										<div class="tech-font text-xs font-bold text-secondary"><FormattedDate date={project.data.pubDate} /></div>
									</div>
								</div>
								<p class="text-xl md:text-2xl text-text-muted leading-relaxed max-w-4xl">
									{project.data.description}
								</p>
							</header>

							<!-- Architecture / Hero Visual -->
							<div class="bg-surface-low p-4 md:p-8 rounded-sm relative overflow-hidden group">
								<div class="relative aspect-video rounded-sm overflow-hidden border border-white/5 bg-surface-highest/30">
									{project.data.heroImage && <img src={project.data.heroImage} alt="" class="w-full h-full object-cover grayscale opacity-40 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-1000" />}
									
									<!-- Architectural Overlay Graphic -->
									<div class="absolute inset-0 p-12 pointer-events-none opacity-10 group-hover:opacity-20 transition-opacity">
										<svg width="100%" height="100%" viewBox="0 0 100 100" class="text-primary stroke-current fill-none stroke-[0.2]">
											<path d="M0 0l100 100M100 0L0 100M50 0v100M0 50h100" />
											<circle cx="50" cy="50" r="40" />
										</svg>
									</div>
								</div>
								<div class="absolute top-12 right-12 tech-font text-[9px] opacity-30 text-right leading-relaxed">
									CORE_SYSTEM_BLUEPRINT<br/>
									VERSION: 2.0.4<br/>
									STATUS: VERIFIED
								</div>
							</div>

							<!-- Detailed Content (from Markdown) -->
							<div class="prose-obsidian max-w-none grid grid-cols-1 md:grid-cols-12 gap-12">
								<div class="md:col-span-4 space-y-8">
									<div class="p-6 bg-surface-low rounded-sm border border-surface-highest/30">
										<span class="tech-label text-[9px] mb-4">Tech_Stack</span>
										<div class="flex flex-wrap gap-2">
											{project.data.stack?.map(s => <span class="px-2 py-1 bg-surface-highest text-[9px] font-bold tech-font text-secondary rounded-sm">{s}</span>)}
										</div>
									</div>
									<div class="flex flex-col gap-4">
										{project.data.githubUrl && <a href={project.data.githubUrl} class="px-6 py-3 bg-primary text-bg-base font-black tech-font text-[10px] text-center rounded-sm hover:bg-secondary transition-colors">[Initialize_Source]</a>}
										{project.data.demoUrl && <a href={project.data.demoUrl} class="px-6 py-3 border border-surface-high font-black tech-font text-[10px] text-center rounded-sm hover:border-primary transition-colors">[Deploy_Live]</a>}
									</div>
								</div>
								<div class="md:col-span-8">
									<div class="text-lg leading-relaxed">
										<Content />
									</div>
								</div>
							</div>
						</article>
					);
				})}
			</section>

			<!-- SECTION 03: LATEST RESEARCH -->
			<section id="logs" class="py-32">
				<div class="flex justify-between items-end mb-16">
					<div>
						<span class="tech-label text-primary mb-4">> Track_B // Learning_Loop</span>
						<h2 class="text-4xl font-bold uppercase tracking-tighter">Recent Exploration</h2>
					</div>
					<a href="/blog" class="tech-font text-[10px] opacity-40 hover:opacity-100 transition-opacity">Access_Full_Archive_</a>
				</div>
				<div class="bg-black/50 backdrop-blur-md rounded-sm border border-surface-highest/30 overflow-hidden">
					{latestLogs.map((log) => (
						<a href={`/${log.collection}/${log.id}/`} class="grid grid-cols-12 gap-4 px-8 py-6 border-b border-white/5 hover:bg-primary/5 transition-colors group no-underline">
							<div class="col-span-2 tech-font text-[10px] text-text-muted mt-1">
								<FormattedDate date={log.data.pubDate} />
							</div>
							<div class="col-span-8 font-bold text-lg group-hover:text-primary transition-colors font-space-grotesk uppercase">
								{log.data.title}
							</div>
							<div class="col-span-2 text-right tech-font text-[9px] text-secondary opacity-60 mt-1 uppercase">
								[{log.collection}]
							</div>
						</a>
					))}
				</div>
			</section>
		</div>

		<!-- Sticky Sidebar Widget (Right) -->
		<aside class="hidden lg:block lg:col-span-3">
			<div class="sticky top-24 space-y-8">
				<div class="glass-panel p-8 rounded-sm">
					<div class="tech-label text-[10px] mb-6 opacity-40">System_Diagnostics</div>
					<div class="space-y-4">
						<div class="flex items-center gap-3">
							<div class="w-2 h-2 bg-primary rounded-full shadow-[0_0_8px_var(--primary)]"></div>
							<span class="text-[10px] tech-font">Core_System: ONLINE</span>
						</div>
						<div class="flex items-center gap-3">
							<div class="w-2 h-2 bg-secondary rounded-full shadow-[0_0_8px_var(--secondary)]"></div>
							<span class="text-[10px] tech-font">AX_Protocol: ACTIVE</span>
						</div>
						<div class="flex items-center gap-3">
							<div class="w-2 h-2 bg-white rounded-full opacity-20"></div>
							<span class="text-[10px] tech-font opacity-40">Remote_Access: READY</span>
						</div>
					</div>
				</div>

				<nav class="p-8 border-l border-white/5 space-y-4">
					<div class="tech-label text-[9px] mb-4 opacity-20">Navigation_Index</div>
					<a href="#identity" class="block text-[10px] tech-font opacity-40 hover:opacity-100 hover:text-primary transition-opacity">01_Identity_Resume</a>
					<a href="#work" class="block text-[10px] tech-font opacity-40 hover:opacity-100 hover:text-primary transition-opacity">02_Project_Showcase</a>
					<a href="#logs" class="block text-[10px] tech-font opacity-40 hover:opacity-100 hover:text-primary transition-opacity">03_Research_Logs</a>
				</nav>
			</div>
		</aside>
	</div>
</MainLayout>

<style>
	.pulse-dot {
		width: 8px;
		height: 8px;
		background-color: var(--primary);
		border-radius: 50%;
		position: relative;
	}
	.pulse-dot::after {
		content: "";
		position: absolute;
		inset: 0;
		border-radius: 50%;
		background-color: var(--primary);
		animation: pulse 2s infinite;
	}
	@keyframes pulse {
		0% { transform: scale(1); opacity: 0.8; }
		100% { transform: scale(3); opacity: 0; }
	}
	
	.project-deep-dive:not(:last-child) {
		border-bottom: 1px solid rgba(255, 255, 255, 0.05);
		padding-bottom: var(--spacing-32);
	}
</style>
