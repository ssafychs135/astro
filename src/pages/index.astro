---
import MainLayout from '../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// 데이터 로드
const projects = (await getCollection('portfolio')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
).slice(0, 3);

const allLogs = [
	...(await getCollection('blog')),
	...(await getCollection('study'))
].sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()).slice(0, 5);
---

<MainLayout>
	<!-- Hero Section -->
	<section class="grid grid-cols-12 gap-8 mb-32">
		<div class="col-span-12 lg:col-span-9">
			<div class="tech-label mb-8">
				<div class="pulse-dot"></div>
				System Status: Optimal // Core: Active
			</div>
			<h1 class="text-6xl md:text-[120px] font-black leading-[0.85] mb-12 tracking-tighter uppercase font-space-grotesk">
				Building<br/>
				<span class="text-primary italic">AX Solutions</span>
			</h1>
			<p class="text-xl md:text-2xl text-text-muted leading-[1.6] max-w-3xl">
				단순한 자동화를 넘어 기업의 비즈니스 아키텍처를 지능형 시스템으로 전환합니다. 
				데이터 주권과 실행력을 갖춘 <span class="text-white font-bold underline decoration-primary/50 underline-offset-8">AI Transformation</span>의 청사진을 제안합니다.
			</p>
		</div>
	</section>

	<!-- Track A: Verified Solutions -->
	<section class="mb-32">
		<div class="flex justify-between items-end mb-16 border-b border-surface-highest/20 pb-8">
			<div>
				<span class="tech-label text-secondary mb-4">> Track_A // Evidence</span>
				<h2 class="text-4xl font-bold uppercase tracking-tighter">Verified Solutions</h2>
			</div>
			<a href={`${base}/portfolio`} class="tech-font text-[10px] opacity-40 hover:opacity-100 transition-opacity mb-2">View_Archive_</a>
		</div>

		<div class="grid grid-cols-1 gap-12">
			{projects.map((project) => (
				<a href={`${base}/portfolio/${project.id}/`} class="group relative block bg-surface-low rounded-sm overflow-hidden hover:bg-surface-high transition-all duration-500 min-h-[400px]">
					<div class="grid grid-cols-1 md:grid-cols-2 h-full">
						<div class="p-12 flex flex-col justify-center relative z-10">
							<div class="tech-label opacity-40 mb-6" style="color: var(--secondary)">
								Record_ID: {project.id.slice(0, 8).toUpperCase()}
							</div>
							<h3 class="text-4xl font-bold mb-6 group-hover:text-primary transition-colors">
								{project.data.title}
							</h3>
							<p class="text-text-muted mb-8 leading-relaxed">
								{project.data.description}
							</p>
							<div class="flex flex-wrap gap-2">
								{project.data.stack?.map(s => <span class="px-2 py-1 bg-surface-highest text-[9px] font-bold tech-font rounded-sm">{s}</span>)}
							</div>
						</div>
						<div class="relative min-h-[300px] md:min-h-full overflow-hidden bg-surface-highest/50">
							{project.data.heroImage && <img src={project.data.heroImage} alt="" class="absolute inset-0 w-full h-full object-cover grayscale opacity-30 group-hover:grayscale-0 group-hover:opacity-60 transition-all duration-700" />}
							<!-- Architecture SVG Fragment -->
							<div class="absolute inset-0 flex items-center justify-center pointer-events-none opacity-10 group-hover:opacity-30 transition-opacity">
								<svg width="200" height="200" viewBox="0 0 100 100" class="text-primary stroke-current fill-none stroke-[0.5]">
									<rect x="10" y="10" width="80" height="80"/>
									<circle cx="50" cy="50" r="30"/>
									<path d="M0 50h100M50 0v100"/>
								</svg>
							</div>
						</div>
					</div>
				</a>
			))}
		</div>
	</section>

	<!-- Identity: Dev Philosophy -->
	<section class="py-32 mb-32 bg-surface-low -mx-6 px-6 md:-mx-12 md:px-12 rounded-lg border-y border-primary/10">
		<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
			<div class="lg:col-span-5">
				<span class="tech-label mb-6">Philosophy // Blueprint</span>
				<h2 class="text-3xl md:text-5xl font-bold mb-8 leading-tight uppercase font-space-grotesk">
					Architecting<br/> 
					<span class="text-secondary italic">Logical Flow</span>
				</h2>
				<p class="text-text-muted leading-relaxed text-lg">
					복잡한 비즈니스 로직을 단순하고 견고한 데이터 흐름으로 변환합니다. 
					성능 지표를 넘어 실제 사용자의 워크플로우가 어떻게 지능적으로 진화하는지에 집중합니다.
				</p>
			</div>
			<div class="lg:col-span-7 grid grid-cols-1 md:grid-cols-3 gap-4">
				<div class="p-8 bg-surface-highest/30 rounded-sm border-t-2 border-primary">
					<div class="text-xs tech-font opacity-40 mb-4">Module_01</div>
					<div class="font-bold">Full-stack AX</div>
				</div>
				<div class="p-8 bg-surface-highest/30 rounded-sm border-t-2 border-secondary">
					<div class="text-xs tech-font opacity-40 mb-4">Module_02</div>
					<div class="font-bold">Architect</div>
				</div>
				<div class="p-8 bg-surface-highest/30 rounded-sm border-t-2 border-white">
					<div class="text-xs tech-font opacity-40 mb-4">Module_03</div>
					<div class="font-bold">AI Eng</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Track B: Research & System Logs -->
	<section class="mb-32">
		<div class="flex justify-between items-end mb-16 border-b border-surface-highest/20 pb-8">
			<div>
				<span class="tech-label text-primary mb-4">> Track_B // Exploration</span>
				<h2 class="text-4xl font-bold uppercase tracking-tighter">Research & System Logs</h2>
			</div>
			<a href={`${base}/blog`} class="tech-font text-[10px] opacity-40 hover:opacity-100 transition-opacity mb-2">Access_Archive_</a>
		</div>

		<div class="bg-black/50 backdrop-blur-md rounded-sm border border-surface-highest/30 overflow-hidden">
			<div class="grid grid-cols-12 gap-4 px-8 py-4 border-b border-surface-highest/30 bg-surface-low/50 tech-font text-[9px] opacity-40">
				<div class="col-span-2">TIMESTAMP</div>
				<div class="col-span-8">LOG_DESCRIPTION</div>
				<div class="col-span-2 text-right">METADATA</div>
			</div>
			{allLogs.map((log) => (
				<a href={`/${log.collection}/${log.id}/`} class="grid grid-cols-12 gap-4 px-8 py-6 border-b border-white/5 hover:bg-primary/5 transition-colors group no-underline">
					<div class="col-span-2 tech-font text-[10px] text-text-muted mt-1">
						<FormattedDate date={log.data.pubDate} />
					</div>
					<div class="col-span-8">
						<div class="font-bold text-lg group-hover:text-primary transition-colors">{log.data.title}</div>
						<p class="text-xs text-text-muted mt-2 line-clamp-1 opacity-60">{log.data.description}</p>
					</div>
					<div class="col-span-2 text-right tech-font text-[9px] text-secondary opacity-60 mt-1 uppercase">
						[{log.collection}]
					</div>
				</a>
			))}
		</div>
	</section>

	<!-- Persistent CTA Terminal -->
	<section class="bg-surface-low p-12 rounded-sm border-l-4 border-primary">
		<div class="max-w-3xl">
			<h2 class="text-3xl font-bold mb-6 font-space-grotesk uppercase">Initialize Connection?</h2>
			<p class="text-text-muted text-lg mb-12 leading-relaxed">
				새로운 지능형 시스템 구축이나 기술적 협업 제안이 있으신가요? 
				아래 채널을 통해 저의 서사와 함께하실 수 있습니다.
			</p>
			<div class="flex flex-wrap gap-6">
				<a href="mailto:contact@example.com" class="px-8 py-4 bg-primary text-bg-base font-black tech-font rounded-sm hover:bg-secondary transition-all transform hover:-translate-y-1">
					[Coffee_Chat_Request]
				</a>
				<a href={`${base}/resume.pdf`} class="px-8 py-4 border border-surface-high font-black tech-font rounded-sm hover:border-primary transition-all transform hover:-translate-y-1">
					[Download_Resume]
				</a>
			</div>
		</div>
	</section>
</MainLayout>

<style>
	/* Page specific visual adjustments if needed */
	.pulse-dot {
		width: 8px;
		height: 8px;
		background-color: var(--primary);
		border-radius: 50%;
		position: relative;
	}
	.pulse-dot::after {
		content: "";
		position: absolute;
		inset: 0;
		border-radius: 50%;
		background-color: var(--primary);
		animation: pulse 2s infinite;
	}
	@keyframes pulse {
		0% { transform: scale(1); opacity: 0.8; }
		100% { transform: scale(3); opacity: 0; }
	}
</style>
