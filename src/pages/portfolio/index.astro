---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const posts = (await getCollection('portfolio')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`AX Solutions | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body class="bg-[#030712] text-slate-50 font-inter">
		<Header />
		<main class="max-w-7xl mx-auto px-6 py-12 md:py-24">
			<h1 class="text-6xl md:text-8xl font-space-grotesk font-bold tracking-tighter mb-16 md:mb-24 border-b border-slate-800 pb-12">
				AX Solutions
			</h1>

			<div class="grid grid-cols-1 md:grid-cols-2 gap-16">
				{posts.map((post) => (
					<article class="group">
						<a href={`${base}/portfolio/${post.id}/`} class="block">
							<div class="relative aspect-video bg-slate-900 rounded-sm overflow-hidden mb-8 border border-slate-800 transition-all duration-500 group-hover:border-accent">
								{post.data.heroImage && (
									<Image width={800} height={450} src={post.data.heroImage} alt="" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 opacity-60 group-hover:opacity-100" />
								)}
								<div class="absolute inset-0 bg-accent/10 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center gap-4">
									<span class="bg-accent text-slate-950 px-6 py-2 rounded-sm font-bold font-space-grotesk text-[10px] tracking-widest uppercase shadow-xl">VIEW_CASE_STUDY</span>
								</div>
								<div class="absolute bottom-4 left-4 font-space-grotesk text-[8px] text-slate-500 uppercase tracking-widest">
									[PROJECT_ID: {post.id.substring(0, 8).toUpperCase()}]
								</div>
							</div>
							<div class="flex justify-between items-start mb-4">
								<h2 class="text-3xl font-space-grotesk font-bold tracking-tight group-hover:text-accent transition-colors duration-500">
									{post.data.title}
								</h2>
								<div class="font-space-grotesk text-xs font-bold text-slate-600 mt-2">
									{(post.data.pubDate).getFullYear()}
								</div>
							</div>
							<p class="text-slate-400 font-light leading-relaxed mb-8 md:text-lg">
								{post.data.description}
							</p>
							<div class="flex flex-wrap gap-2">
								{post.data.stack && post.data.stack.map(item => (
									<span class="px-3 py-1 bg-slate-900 text-accent border border-accent/20 rounded-sm text-[10px] font-bold font-space-grotesk uppercase tracking-wider">
										{item}
									</span>
								))}
							</div>
						</a>
					</article>
				))}
			</div>
		</main>
		<Footer />
	</body>
</html>
