---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('portfolio')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Portfolio | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body class="bg-white text-slate-900 font-inter">
		<Header />
		<main class="max-w-7xl mx-auto px-6 py-12 md:py-24">
			<h1 class="text-6xl md:text-8xl font-plus-jakarta font-extrabold tracking-tighter mb-16 md:mb-24 border-b border-slate-100 pb-12">
				Portfolio
			</h1>

			<div class="grid grid-cols-1 md:grid-cols-2 gap-16">
				{posts.map((post) => (
					<article class="group">
						<a href={`/portfolio/${post.id}/`} class="block">
							<div class="relative aspect-video bg-slate-100 rounded-[40px] overflow-hidden mb-8 border border-slate-50 shadow-sm transition-all duration-500 group-hover:shadow-2xl group-hover:shadow-purple-100/50">
								{post.data.heroImage && (
									<Image width={800} height={450} src={post.data.heroImage} alt="" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
								)}
								<div class="absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center gap-4">
									{post.data.demoUrl && (
										<span class="bg-white text-black px-6 py-2 rounded-full font-bold text-sm shadow-xl transform translate-y-4 group-hover:translate-y-0 transition-all duration-500">Live Demo</span>
									)}
									{post.data.githubUrl && (
										<span class="bg-slate-900 text-white px-6 py-2 rounded-full font-bold text-sm shadow-xl transform translate-y-4 group-hover:translate-y-0 transition-all duration-500 delay-75">GitHub</span>
									)}
								</div>
							</div>
							<div class="flex justify-between items-start mb-4">
								<h2 class="text-3xl font-plus-jakarta font-extrabold tracking-tight group-hover:text-accent-secondary transition-colors duration-500">
									{post.data.title}
								</h2>
								<div class="font-space-grotesk text-xs font-bold text-slate-300 mt-2">
									{(post.data.pubDate).getFullYear()}
								</div>
							</div>
							<p class="text-slate-500 font-light leading-relaxed mb-8 md:text-lg">
								{post.data.description}
							</p>
							<div class="flex flex-wrap gap-2">
								{post.data.stack && post.data.stack.map(item => (
									<span class="px-4 py-1.5 bg-purple-50 text-accent-secondary rounded-full text-[10px] font-bold font-space-grotesk uppercase tracking-wider">
										{item}
									</span>
								))}
							</div>
						</a>
					</article>
				))}
			</div>
		</main>
		<Footer />
	</body>
</html>
