---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'portfolio'>['data'];

const { title, description, pubDate, updatedDate, heroImage, stack, githubUrl, demoUrl, role } = Astro.props;
---

<html lang="ko">
	<head>
		<BaseHead title={title} description={description} />
	</head>

	<body class="bg-bg-base text-text-base antialiased">
		<Header />
		<main class="max-w-5xl mx-auto px-6 py-24">
			<article>
				<header class="mb-16">
					<div class="tech-label mb-8">
						<span class="text-secondary">> Case_Study // 01</span>
						<span class="opacity-30">Status: Verified</span>
					</div>
					<h1 class="text-5xl md:text-8xl font-black tracking-tighter uppercase mb-12 leading-[0.9]">
						{title}
					</h1>
					
					<p class="text-xl md:text-2xl text-text-muted leading-relaxed max-w-3xl mb-12">
						{description}
					</p>

					<div class="telemetry-bar">
						<div class="telemetry-item">
							<span class="tech-label opacity-40 !text-[9px]">Timestamp</span>
							<span class="font-bold"><FormattedDate date={pubDate} /></span>
						</div>
						<div class="telemetry-item">
							<span class="tech-label opacity-40 !text-[9px]">Primary_Role</span>
							<span class="font-bold uppercase tech-font text-xs tracking-widest">{role || 'Architect'}</span>
						</div>
						<div class="telemetry-item">
							<span class="tech-label opacity-40 !text-[9px]">Tech_Stack</span>
							<div class="flex flex-wrap gap-2">
								{stack?.map(s => <span class="tag-obsidian">{s}</span>)}
							</div>
						</div>
					</div>

					<div class="flex gap-6 mt-12">
						{githubUrl && (
							<a href={githubUrl} class="px-8 py-3 bg-primary text-bg-base font-black tech-font rounded-sm hover:bg-secondary transition-colors">
								Initialize_Source
							</a>
						)}
						{demoUrl && (
							<a href={demoUrl} class="px-8 py-3 border border-surface-high font-black tech-font rounded-sm hover:border-primary transition-colors">
								Deploy_Live
							</a>
						)}
					</div>
				</header>

				{heroImage && (
					<div class="blueprint-frame">
						<div class="rounded-sm overflow-hidden border border-white/5">
							<Image width={1200} height={600} src={heroImage} alt="" class="w-full h-auto grayscale hover:grayscale-0 transition-all duration-1000" />
						</div>
					</div>
				)}
				
				<div class="prose-obsidian max-w-none">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
