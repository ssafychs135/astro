---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'portfolio'>['data'];

const { title, description, pubDate, updatedDate, heroImage, stack, githubUrl, demoUrl, role } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>

	<body class="bg-white text-slate-900 font-inter">
		<Header />
		<main class="max-w-5xl mx-auto px-6 py-12 md:py-24">
			<article>
				<!-- Hero Section -->
				<div class="mb-16 md:mb-24">
					<div class="font-space-grotesk text-xs font-bold text-slate-400 mb-6 tracking-[0.2em] uppercase flex items-center gap-4">
						<span class="text-accent-secondary">Project Showcase</span>
						<span>/</span>
						<FormattedDate date={pubDate} />
					</div>
					<h1 class="text-5xl md:text-7xl font-plus-jakarta font-extrabold tracking-tighter mb-8 leading-[1.1]">{title}</h1>
					
					<!-- Links and Metadata -->
					<div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-8 mb-12 py-8 border-y border-slate-100">
						<div class="flex flex-col gap-4">
							{role && (
								<div class="flex items-center gap-3">
									<span class="font-space-grotesk text-[10px] font-bold text-slate-400 uppercase tracking-widest">Role</span>
									<span class="text-slate-700 font-semibold">{role}</span>
								</div>
							)}
							<div class="flex flex-wrap gap-2">
								{stack && stack.map((item) => (
									<span class="px-3 py-1 bg-purple-50 text-accent-secondary rounded-full text-[10px] font-bold font-space-grotesk uppercase tracking-wider">{item}</span>
								))}
							</div>
						</div>
						
						<div class="flex gap-4">
							{githubUrl && (
								<a href={githubUrl} target="_blank" rel="noopener noreferrer" 
									class="px-6 py-3 bg-slate-900 text-white rounded-full font-bold text-sm shadow-xl hover:bg-black transition-all">
									GitHub
								</a>
							)}
							{demoUrl && (
								<a href={demoUrl} target="_blank" rel="noopener noreferrer" 
									class="px-6 py-3 bg-white border border-slate-200 text-black rounded-full font-bold text-sm shadow-lg hover:border-accent-secondary transition-all">
									Live Demo
								</a>
							)}
						</div>
					</div>

					{heroImage && (
						<div class="rounded-[40px] overflow-hidden border border-slate-100 shadow-2xl shadow-purple-100/20">
							<Image width={1200} height={600} src={heroImage} alt="" class="w-full h-auto" />
						</div>
					)}
				</div>
				
				<!-- Content -->
				<div class="prose prose-slate prose-xl max-w-3xl mx-auto
					prose-headings:font-plus-jakarta prose-headings:font-extrabold prose-headings:tracking-tight
					prose-p:font-light prose-p:leading-relaxed prose-p:text-slate-600
					prose-a:text-accent-secondary hover:prose-a:text-purple-700
					prose-img:rounded-[32px] prose-img:border prose-img:border-slate-50
					prose-blockquote:border-l-accent-secondary prose-blockquote:bg-slate-50 prose-blockquote:py-2 prose-blockquote:px-8 prose-blockquote:rounded-r-2xl
					prose-code:font-space-grotesk prose-code:bg-slate-100 prose-code:px-1 prose-code:rounded">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
