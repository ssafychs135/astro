---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>

	<body class="bg-white text-slate-900 font-inter">
		<Header />
		<main class="max-w-5xl mx-auto px-6 py-12 md:py-24">
			<article>
				<!-- Hero Section -->
				<div class="mb-16 md:mb-24">
					<div class="font-space-grotesk text-xs font-bold text-slate-400 mb-6 tracking-[0.2em] uppercase flex items-center gap-4">
						<span class="text-accent">Research Report</span>
						<span>/</span>
						<FormattedDate date={pubDate} />
					</div>
					<h1 class="text-5xl md:text-7xl font-plus-jakarta font-extrabold tracking-tighter mb-10 leading-[1.1]">{title}</h1>
					<p class="text-xl md:text-2xl text-slate-500 font-light leading-relaxed mb-12 max-w-3xl border-l-4 border-blue-50 pl-8">
						{description}
					</p>
					{heroImage && (
						<div class="rounded-[40px] overflow-hidden border border-slate-100 shadow-2xl shadow-blue-100/20">
							<Image width={1200} height={600} src={heroImage} alt="" class="w-full h-auto" />
						</div>
					)}
				</div>
				
				<!-- Content -->
				<div class="prose prose-slate prose-xl max-w-3xl mx-auto
					prose-headings:font-plus-jakarta prose-headings:font-extrabold prose-headings:tracking-tight
					prose-p:font-light prose-p:leading-relaxed prose-p:text-slate-600
					prose-a:text-accent hover:prose-a:text-blue-700
					prose-img:rounded-[32px] prose-img:border prose-img:border-slate-50
					prose-blockquote:border-l-accent prose-blockquote:bg-slate-50 prose-blockquote:py-2 prose-blockquote:px-8 prose-blockquote:rounded-r-2xl
					prose-code:font-space-grotesk prose-code:bg-slate-100 prose-code:px-1 prose-code:rounded">
					<slot />
					
					{updatedDate && (
						<div class="mt-20 pt-8 border-t border-slate-100 font-space-grotesk text-[10px] text-slate-300 uppercase tracking-widest text-center">
							Last updated on <FormattedDate date={updatedDate} />
						</div>
					)}
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
